# Copy to .env for local development. Do NOT commit the real .env.
DEBUG=True
SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=*

# Local dev uses SQLite by default — leave DATABASE_URL unset.
#
# Later (deployment step), a docker-compose.yml will provide a Postgres:16
# service for production parity. To use it, uncomment and point at the container:
# DATABASE_URL=postgres://packlist:packlist@localhost:5432/packlist
#
# Cloud Run (production) injects DATABASE_URL + CSRF_TRUSTED_ORIGINS from
# Secret Manager / service config:
# CSRF_TRUSTED_ORIGINS=https://your-service.run.app
